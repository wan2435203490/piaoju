# 复制为 .env 后按需修改；所有服务端配置以 PIAOJU_ 为前缀
PIAOJU_HTTP_ADDR=:8080
PIAOJU_DB_DSN=piaoju:piaoju@tcp(127.0.0.1:3306)/piaoju?parseTime=true&loc=UTC&charset=utf8mb4
PIAOJU_JWT_SECRET=change-me-32-bytes-minimum-secret!!
PIAOJU_ACCESS_TTL=15m
PIAOJU_REFRESH_TTL=720h
PIAOJU_UPLOAD_DIR=./uploads
PIAOJU_UPLOAD_MAX_MB=10

# docker-compose 用
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=piaoju
MYSQL_USER=piaoju
MYSQL_PASSWORD=piaoju

# 宿主端口可用 PIAOJU_MYSQL_PORT 避让（默认 3306）
# PIAOJU_MYSQL_PORT=3316
